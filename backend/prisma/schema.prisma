generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String
  googleId      String?        @unique
  role          Role           @default(USER)
  emailVerified DateTime?
  image         String?
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  imageId       String?
  builds        Build[]
  cartItems     CartItem[]
  orders        Order[]
  reviews       Review[]
  avatar        Image?         @relation(fields: [imageId], references: [id])
  wishlistItems WishlistItem[]
  payments      Payment[]
}

model Image {
  id        String         @id @default(cuid())
  filename  String
  path      String
  url       String
  mimetype  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime       @default(now())
  banners   Banner[]
  brands    Brand[]        @relation("BrandLogo")
  products  ProductImage[]
  users     User[]
}

model Product {
  id               String           @id @default(cuid())
  name             String
  description      String
  price            Decimal          @db.Decimal(10, 2)
  brand            String
  images           String[]
  category         String?
  stock            Int
  specifications   Json
  powerConsumption Int?
  platform         String? // "Intel" | "AMD" - brand/platform matching
  socketType       String? // e.g. "LGA 1700", "AM5", "AM4" - generation matching
  memoryType       String? // "DDR4" | "DDR5" - memory type matching
  avgRating        Float            @default(0)
  totalReviews     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  compareAtPrice   Decimal?         @db.Decimal(10, 2)
  isNewArrival     Boolean          @default(true)
  buildComponents  BuildComponent[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  productImages    ProductImage[]
  reviews          Review[]
  sectionItems     SectionItem[]
  wishlistItems    WishlistItem[]
  coupons          Coupon[]

  @@index([name, brand, category])
}

model ProductImage {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  productId String
  imageId   String
  createdAt DateTime @default(now())
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, imageId])
  @@index([productId, order])
}

model CartItem {
  id              String   @id @default(cuid())
  quantity        Int
  userId          String
  productId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customPrice     Decimal? @db.Decimal(10, 2)
  buildComponents Json?
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  shippingAddress Json
  statusHistory   Json[]
  trackingNumber  String?
  discountAmount  Decimal?    @db.Decimal(10, 2)
  couponCode      String?
  userId          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payments        Payment[]
}

model OrderItem {
  id              String   @id @default(cuid())
  quantity        Int
  price           Decimal  @db.Decimal(10, 2)
  orderId         String
  productId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  buildComponents Json?
  customPrice     Decimal? @db.Decimal(10, 2)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Build {
  id             String           @id @default(cuid())
  name           String
  description    String?
  isPublic       Boolean          @default(false)
  isTemplate     Boolean          @default(false)
  userId         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  imageUrl       String?
  discountAmount Decimal?         @db.Decimal(10, 2)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  components   BuildComponent[]
  sectionItems SectionItem[]
  coupons      Coupon[]
}

model BuildComponent {
  id        String   @id @default(cuid())
  category  String?
  buildId   String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([buildId, productId])
  @@index([buildId, category])
}

model Banner {
  id          String         @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  link        String?
  isActive    Boolean        @default(true)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  position    BannerPosition @default(MAIN_SLIDER)
  imageId     String?
  image       Image?         @relation(fields: [imageId], references: [id])

  @@index([isActive, position, order])
}

model Brand {
  id         String   @id @default(cuid())
  name       String   @unique
  nameAr     String?
  logo       String?
  slug       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  categories String[]
  logoId     String?
  logoImage  Image?   @relation("BrandLogo", fields: [logoId], references: [id])

  @@index([isActive, slug])
}

model BuildOrder {
  id              String           @id @default(cuid())
  orderNumber     String           @unique
  customerPhone   String
  customerName    String?
  customerAddress String
  notes           String?
  totalAmount     Decimal          @db.Decimal(10, 2)
  status          BuildOrderStatus @default(NEW)
  components      Json
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
}

model Section {
  id        String        @id @default(cuid())
  title     String
  titleAr   String?
  slug      String        @unique
  type      SectionType   @default(MIXED)
  order     Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     SectionItem[]
}

model SectionItem {
  id        String   @id @default(cuid())
  sectionId String
  productId String?
  buildId   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  build     Build?   @relation(fields: [buildId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, productId])
  @@unique([sectionId, buildId])
}

enum Role {
  USER
  ADMIN
  CHATBOT
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BuildOrderStatus {
  NEW
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BannerPosition {
  MAIN_SLIDER
  SECONDARY_TOP
  SECONDARY_BOTTOM
}

enum SectionType {
  PRODUCT
  BUILD
  MIXED
}

model DisplayCategory {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  slug      String   @unique
  icon      String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

model Payment {
  id      String @id @default(cuid())
  userId  String
  orderId String @unique

  // SindiPay fields
  sindiPayId  Int?    @unique
  sindiPayUrl String?

  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("IQD")
  status   PaymentStatus @default(PENDING)

  title  String
  locale String @default("ar")

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([sindiPayId])
}

enum PaymentStatus {
  PENDING
  CREATED
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

model Coupon {
  id                    String       @id @default(cuid())
  code                  String       @unique
  discountType          DiscountType // PERCENTAGE or FIXED
  discountValue         Decimal      @db.Decimal(10, 2)
  isActive              Boolean      @default(true)
  expiryDate            DateTime?
  usageLimit            Int?
  usedCount             Int          @default(0)
  applicableProducts    Product[]
  applicableBuilds      Build[]
  applicableCategories  String[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model SiteSettings {
  id            String   @id @default("main")
  buildDiscount Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
